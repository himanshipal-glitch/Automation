# Rename this file to  secrets.toml  and fill in your values to enable the "Send to team" button.
# The App Password is NOT your Gmail login password — create one at:
#   Google Account → Security → 2-Step Verification → App passwords

[email]
sender       = "you@recykal.com"
app_password = "xxxx xxxx xxxx xxxx"
recipients   = ["person1@recykal.com", "person2@recykal.com"]

# Enable the in-app AI assistant "Recy":
[gemini]
api_key = "YOUR_GEMINI_API_KEY"     # from https://aistudio.google.com/app/apikey
