# Rename this file to  secrets.toml  and fill in your values to enable the "Send to team" button.
# The App Password is NOT your Gmail login password — create one at:
#   Google Account → Security → 2-Step Verification → App passwords

[email]
sender       = "you@recykal.com"
app_password = "xxxx xxxx xxxx xxxx"
recipients   = ["person1@recykal.com", "person2@recykal.com"]

# Enable the in-app AI assistant "Recy":
[gemini]
api_key = "YOUR_GEMINI_API_KEY"     # from https://aistudio.google.com/app/apikey

# ── Durable manual-entry stores (hosted) ──────────────────────────────────────
# Streamlit Cloud wipes the container disk on every restart/redeploy. With this
# section set, saving Enterprise Custom Duty bills / Operational Cost overrides
# auto-commits the store file to the repo, so the values come back after any
# redeploy. Token: GitHub fine-grained PAT with "Contents: Read and write"
# permission on the repo below.
[github]
token = "github_pat_xxdo-not-commit-real-tokenxx"
repo = "himanshipal-glitch/Automation"
branch = "main"
